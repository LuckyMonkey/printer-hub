GAPPS_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec

# Printer Hub unified print API
API_RATE_LIMIT_PER_MIN=60
PRINT_ERROR_HISTORY_LIMIT=20
PRINT_SOCKET_TIMEOUT_SEC=4
PRINT_JOB_LOG_PATH=/var/log/printer-hub/print-jobs.log

# Zebra ZP-505
ZEBRA_TRANSPORT=cups
ZEBRA_HOST=192.168.1.120
ZEBRA_PORT=9100
PRINTER_ZEBRA_QUEUE=zebra_zp505

# Brother QL-820NWB (P-touch Template mode)
BROTHER_MODE=template
BROTHER_TRANSPORT=socket
BROTHER_HOST=192.168.1.121
BROTHER_PORT=9100
PRINTER_BROTHER_QUEUE=brother_ql820nwb

# HP Envy 5055
PRINTER_HP_QUEUE=hp_envy_5055
